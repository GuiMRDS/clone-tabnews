{
  "name": "clone-tabnews",
  "version": "1.0.0",
  "description": "Um projeto teste para aprender de fora a fora um projeto do Zero",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run services:wait:database && npm run migrations:up & next dev",
    "test": "npm run services:up && npm run services:wait:database && concurrently -n next,jest --hide next -k -s command-jest 'next dev' 'jest --runInBand'",
    "test:watch": "jest --watchAll --runInBand",
    "posttest": "npm run services:stop",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:wait:database": "node infra/scripts/wait-for-postgres.js",
    "migrations:create": "node-pg-migrate -m infra/migrations create",
    "migrations:up": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "prepare": "husky",
    "commit": "cz"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@commitlint/cli": "21.0.1",
    "async-retry": "1.3.3",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "next": "16.2.6",
    "node-pg-migrate": "8.0.4",
    "pg": "8.20.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "21.0.1",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.6",
    "commitizen": "4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "husky": "9.1.7",
    "jest": "30.4.2",
    "prettier": "3.8.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
